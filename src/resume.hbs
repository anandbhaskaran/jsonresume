<!doctype html>
<html>

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, user-scalable=no, minimal-ui">
  <title>{{#resume.basics}}{{name}}{{/resume.basics}}</title>
  <link href="https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Newsreader:ital,wght@1,400;1,500&display=swap" rel="stylesheet">
  {{{ style }}}
</head>

<body>
  <main id="resume" class="page">
    {{> resume-header}}
    {{> metrics}}
    {{> summary}}
    <div class="resume-content">
      {{> work}}
      {{> projects}}
      {{> skills}}
      {{> languages}}
      <div class="bottom-row">
        {{> education}}
        {{> certificates}}
        {{> awards}}
      </div>
      {{> volunteer}}
      {{> publications}}
      {{> references}}
    </div>
  </main>

  <script>
    (function () {
      // Wrap each major section container in <details open> so it's collapsible
      document.querySelectorAll('.resume-content .container').forEach(function (container) {
        var title = container.querySelector(':scope > .title');
        if (!title) return;

        var details = document.createElement('details');
        details.open = true;
        details.className = 'section-collapse';

        var summary = document.createElement('summary');
        summary.className = 'section-collapse-summary';
        summary.appendChild(title); // moves .title into summary

        details.appendChild(summary);

        // Move remaining children (items) into details
        while (container.firstChild) {
          details.appendChild(container.firstChild);
        }

        container.appendChild(details);
      });

      // Before printing: force all collapsed sections open
      window.addEventListener('beforeprint', function () {
        document.querySelectorAll('details.section-collapse').forEach(function (d) {
          d._wasOpen = d.open;
          d.open = true;
        });
      });

      // Restore state after print dialog closes
      window.addEventListener('afterprint', function () {
        document.querySelectorAll('details.section-collapse').forEach(function (d) {
          if (typeof d._wasOpen !== 'undefined') {
            d.open = d._wasOpen;
            delete d._wasOpen;
          }
        });
      });
    })();
  </script>
</body>

</html>
