{{#if resume.awards.length}}
<div class="container awards-container">
    {{> title value="Awards"}}

    <div class="awards-list">
        {{#each resume.awards}}
        <div class="award-item">
            <strong>{{title}}</strong>
            {{#if awarder}}<span class="awarder">{{awarder}}{{#if date}} ({{date}}){{/if}}</span>{{/if}}
            {{#if summary}}<span class="award-summary">{{summary}}</span>{{/if}}
            {{#if url}}<a href="{{url}}" class="award-url">View Award</a>{{/if}}
        </div>
        {{/each}}
    </div>
</div>
{{/if}}
